generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum LogLevel {
  DEBUG
  INFO
  WARN
  ERROR
  FATAL
}

model Enterprises {
  id              String    @id @default(uuid()) @db.Uuid
  name            String    
  apiId           String    @unique
  apiKey          String    @unique 

  cnpj            String    @unique

  logs            Logs[]
  users           Users[]
  @@map("enterprise")
}

model Users {
  id              String          @id @default(uuid()) @db.Uuid
  email           String          @unique
  password        String
  enterpriseId    String          @map("enterprise_id") @db.Uuid
  enterprises     Enterprises     @relation(fields: [enterpriseId], references: [id], onDelete: Cascade)
  refreshToken    RefreshToken[]
  @@map("users")
}


model RefreshToken {
  id              String    @id @default(uuid()) @db.Uuid

  userId          String    @db.Uuid @map("client_id")
  users           Users     @relation(fields: [userId], references: [id], onDelete: Cascade)

  jti             String    @unique
  expiresAt       DateTime  @map("expires_at")
  revokedAt       DateTime? @map("revoked_at")

  @@map("refresh_token")
}

model Logs {
  id                String @id @default(uuid()) @db.Uuid

  service           String
  module            String
  action            String

  level             LogLevel

  message           String

  traceId           String @map("trace_id")

  externalUserId    String? @map("external_user_id")

  environment       String?

  metadata          Json?

  enterpriseId      String @db.Uuid @map("enterprise_id")
  enterprise        Enterprises @relation(fields: [enterpriseId], references: [id])

  createdAt         DateTime @default(now()) @map("created_at")

  @@index([service])
  @@index([module])
  @@index([action])
  @@index([level])
  @@index([traceId])

  @@map("logs")
}
