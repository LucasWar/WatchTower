generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model logs {
  id        String   @id @default(uuid()) @db.Uuid
  service   String
  module    String
  action    String
  level     String
  message   String
  traceId   String   @map("trace_id")
  userId    String   @map("user_id")
  metadata  Json?
  createdAt DateTime? @map("created_at") @default(now())
}
